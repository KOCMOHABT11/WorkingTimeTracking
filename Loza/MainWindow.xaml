<Window x:Class="Lota.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:pages="clr-namespace:Lota.Views.Pages"
        Title="Учет рабочего времени «Лоза»" Height="650" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}">
    <Window.Resources>
        <Style TargetType="ListBox" BasedOn="{StaticResource MaterialDesignListBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            Padding="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True"/>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="129*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель меню -->
        <Border Grid.Column="0" Background="{DynamicResource PrimaryHueDarkBrush}">
            <Grid Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип / название -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="ООО ЛОЗА" Foreground="White" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="учёт рабочего времени" Foreground="#AAFFFFFF" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Пункты меню -->
                <ListBox Grid.Row="1" x:Name="MenuListBox"
                         Background="Transparent" BorderThickness="0"
                         Foreground="White" FontSize="14"
                         SelectionChanged="MenuListBox_SelectionChanged">
                    <ListBoxItem Tag="Employees" Padding="0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Сотрудники" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="TimeLog" Padding="0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <materialDesign:PackIcon Kind="ClockFast" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Журнал времени" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Timesheet" Padding="0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <materialDesign:PackIcon Kind="CalendarBadge" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Табель" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Admin" Padding="0">
                        <Grid Margin="20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ShieldAccount" Width="15" Height="15" 
                                 VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Grid.Column="1" Text="Администрирование" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" x:Name="pendingBadge" Background="Red" CornerRadius="10" 
                MinWidth="18" Height="18" Margin="0,0,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="pendingCountText" Text="0" Foreground="White" FontSize="11" 
                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Margin="5,0"/>
                            </Border>
                        </Grid>
                    </ListBoxItem>
                </ListBox>

                <!-- Информация о пользователе и выход -->
                <StackPanel Grid.Row="2" Margin="0,20,0,20" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtUser" Foreground="White" FontSize="12" 
                               TextAlignment="Center" Margin="0,0,0,5"/>
                    <Separator Background="#44FFFFFF" Margin="15,0"/>
                    <Button Content="Выход" Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" FontSize="12"
                            Click="BtnExit_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Правая часть (контент) -->
        <Border Grid.Column="1" Background="{DynamicResource MaterialDesignLightBackground}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок страницы -->
                <TextBlock x:Name="lblPageTitle" 
                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                   Margin="0,0,0,15" />

                <!-- Область контента (загружаемые страницы) -->
                <ContentControl x:Name="ContentArea" Grid.Row="1"/>
            </Grid>
        </Border>
    </Grid>
</Window>