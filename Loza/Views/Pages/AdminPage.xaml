<UserControl x:Class="Lota.Views.Pages.AdminPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <!-- Стиль строки таблицы с подсветкой ожидающих -->
        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsApproved}" Value="False">
                    <Setter Property="Background" Value="#FFE0E0"/>
                    <!-- светло-красный -->
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и переключатель -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Управление пользователями" Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
            <ComboBox x:Name="cmbFilter" Width="180"
                      materialDesign:HintAssist.Hint="Фильтр"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      SelectedValuePath="Tag"
                      SelectionChanged="CmbFilter_SelectionChanged">
                <ComboBoxItem Content="Ожидают подтверждения" Tag="pending"/>
                <ComboBoxItem Content="Активные" Tag="approved"/>
                <ComboBoxItem Content="Все" Tag="all"/>
            </ComboBox>
        </StackPanel>

        <!-- Панель действий -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Одобрить" Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                    Margin="0,0,10,0" Click="BtnApprove_Click"/>
            <Button Content="Отклонить" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,10,0" Click="BtnReject_Click"/>
            <Button Content="Редактировать" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,10,0" Click="BtnEdit_Click"/>
            <Button Content="Удалить" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="BtnDelete_Click"/>
        </StackPanel>

        <!-- Таблица пользователей -->
        <DataGrid Grid.Row="2" x:Name="gridUsers"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="0" />
                <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Статус" Width="Auto">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{Binding IsApproved, Converter={StaticResource BoolToStatusConverter}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>