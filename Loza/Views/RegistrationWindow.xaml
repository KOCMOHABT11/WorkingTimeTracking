<Window x:Class="Lota.Views.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Регистрация" Height="480" Width="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Создание учётной записи" Grid.Row="0" 
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBox Grid.Row="1" x:Name="txtUsername" Margin="0,5"
                 materialDesign:HintAssist.Hint="Имя пользователя"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

        <TextBox Grid.Row="2" x:Name="txtFullName" Margin="0,5"
                 materialDesign:HintAssist.Hint="Полное имя"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

        <TextBox Grid.Row="3" x:Name="txtEmail" Margin="0,5"
                 materialDesign:HintAssist.Hint="Email"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

        <PasswordBox Grid.Row="4" x:Name="txtPassword" Margin="0,5"
                     materialDesign:HintAssist.Hint="Пароль"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" />

        <PasswordBox Grid.Row="5" x:Name="txtConfirmPassword" Margin="0,5"
                     materialDesign:HintAssist.Hint="Подтверждение пароля"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" />

        <!-- Сообщение с прокруткой, чтобы не перекрыло кнопки -->
        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto" MaxHeight="80" Margin="0,5">
            <TextBlock x:Name="txtMessage" Foreground="SeaGreen"
                       TextWrapping="Wrap" />
        </ScrollViewer>

        <!-- Кнопки фиксированы снизу -->
        <StackPanel Grid.Row="7" Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
            <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ" Margin="0,0,10,0"
                    Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                    Click="BtnRegister_Click" />
            <Button Content="ОТМЕНА" Style="{StaticResource MaterialDesignFlatButton}"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>