<Window x:Class="Lota.Views.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Редактирование пользователя" Height="435" Width="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Редактирование данных" 
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,15"/>

        <TextBox Grid.Row="1" x:Name="txtUsername" Margin="0,5"
                 materialDesign:HintAssist.Hint="Логин"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
        <TextBox Grid.Row="2" x:Name="txtFullName" Margin="0,5"
                 materialDesign:HintAssist.Hint="ФИО"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
        <TextBox Grid.Row="3" x:Name="txtEmail" Margin="0,5"
                 materialDesign:HintAssist.Hint="Email"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

        <!-- Роль -->
        <ComboBox Grid.Row="4" x:Name="cmbRole" Margin="0,5"
                  materialDesign:HintAssist.Hint="Роль"
                  Style="{StaticResource MaterialDesignFloatingHintComboBox}">
            <ComboBoxItem Content="Пользователь" Tag="user"/>
            <ComboBoxItem Content="Администратор" Tag="admin"/>
        </ComboBox>

        <!-- Чекбокс смены пароля -->
        <CheckBox Grid.Row="5" x:Name="chkChangePassword" Content="Сменить пароль" 
                  Margin="0,10,0,5" VerticalAlignment="Center"/>
        <PasswordBox Grid.Row="6" x:Name="txtNewPassword" 
                     materialDesign:HintAssist.Hint="Новый пароль"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                     IsEnabled="{Binding IsChecked, ElementName=chkChangePassword}" Margin="0,5"/>

        <StackPanel Grid.Row="7" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,15,0,0">
            <Button Content="Сохранить" Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                    IsDefault="True" Click="BtnSave_Click" Margin="0,0,10,0"/>
            <Button Content="Отмена" Style="{StaticResource MaterialDesignOutlinedButton}"
                    IsCancel="True" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>